# Copy this file to .env and fill in your real key.
#   cp .env.example .env        (macOS/Linux)
#   Copy-Item .env.example .env (Windows PowerShell)
#
# Get a key at https://console.anthropic.com → Settings → API keys.
# .env is gitignored - never commit your real key.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model used by the agent. Develop on the cheap Haiku model; switch to
# claude-sonnet-4-6 for the final demo for stronger SQL reasoning.
ANALYST_MODEL=claude-haiku-4-5
